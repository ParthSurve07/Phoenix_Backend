generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  portfolios   Portfolio[]
  riskInsights RiskInsight[]
}

model Portfolio {
  id           String   @id @default(uuid())
  userId       String
  symbol       String
  quantity     Float
  avgPrice     Float
  currentPrice Float
  marketValue  Float
  pnl          Float
  source       String
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model Prediction {
  id            String   @id @default(uuid())
  symbol        String
  mlProbability Float
  trendScore    Float
  momentumScore Float
  hybridScore   Float
  signal        String
  generatedAt   DateTime @default(now())
}

model RiskInsight {
  id           String   @id @default(uuid())
  userId       String
  analysisText String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}